# GAIA Kernel Configuration Template
# Copy this file to .env and fill in your actual values.

# Security & Compliance (SENSITIVE - Change these!)
# GAIA_AUDIT_SECRET: HMAC-SHA256 secret for cryptographic audit log signing
GAIA_AUDIT_SECRET=your_32_character_hex_secret_here
# GAIA_ADMIN_TOKEN: Token for protected Admin API operations
GAIA_ADMIN_TOKEN=your_secure_admin_token_here

# LLM Planner Configuration
# Provider: 'local' (Ollama) or 'cloud' (OpenAI/Anthropic)
GAIA_PLANNER_PROVIDER=local

# Local Planner Config (Ollama)
GAIA_PLANNER_ENDPOINT=http://localhost:11434/api/generate
GAIA_PLANNER_MODEL=phi3:mini

# Cloud Planner Config (Optional)
# GAIA_PLANNER_ENDPOINT=https://api.openai.com/v1/chat/completions
# GAIA_PLANNER_MODEL=gpt-4o-mini
# GAIA_PLANNER_API_KEY=your_api_key_here

# Persistence Configuration
# Path to the persistent SQLite database
GAIA_DB_PATH=./data/gaia_state.db
# Path to the tamper-proof audit log file
GAIA_AUDIT_LOG_PATH=./data/audit.log

# Logging & Observability
# Log level: DEBUG, INFO, WARN, ERROR
GAIA_LOG_LEVEL=INFO
