{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Event",
  "$defs": {
    "Event": {
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "payload": {
          "type": "object"
        },
        "task_id": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "sequence_number": {
          "type": "integer"
        },
        "previous_event_id": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "name",
        "timestamp"
      ]
    }
  }
}