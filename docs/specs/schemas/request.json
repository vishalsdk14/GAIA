{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Request",
  "$defs": {
    "Request": {
      "properties": {
        "type": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        },
        "capability": {
          "type": "string"
        },
        "input": true,
        "mode": {
          "type": "string"
