{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Step",
  "$defs": {
    "Error": {
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "code",
        "message",
        "retryable"
      ]
    },
    "Step": {
      "properties": {
        "step_id": {
          "type": "string"
        },
        "capability": {
          "type": "string"
        },
        "input": true,
        "depends_on": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "type": "string"
        },
        "job_id": {
          "type": "string"
        },
        "async_timeout_ms": {
          "type": "integer"
        },
        "assigned_agent": {
          "type": "string"
        },
        "output": true,
        "output_schema": {
          "type": "object"
        },
        "error": {
          "$ref": "#/$defs/Error"
        },
        "retry_count": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "step_id",
        "capability",
        "input",
        "status",
        "retry_count"
      ]
    }
  }
}