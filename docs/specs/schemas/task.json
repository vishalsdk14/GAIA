{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Task",
  "$defs": {
    "Error": {
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "code",
        "message",
        "retryable"
      ]
    },
    "Step": {
      "properties": {
        "step_id": {
          "type": "string"
        },
        "capability": {
          "type": "string"
        },
        "input": true,
        "depends_on": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "type": "string"
        },
        "job_id": {
          "type": "string"
        },
        "async_timeout_ms": {
          "type": "integer"
        },
        "assigned_agent": {
          "type": "string"
        },
        "output": true,
        "output_schema": {
          "type": "object"
        },
        "error": {
          "$ref": "#/$defs/Error"
        },
        "retry_count": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "step_id",
        "capability",
        "input",
        "status",
        "retry_count"
      ]
    },
    "Task": {
      "properties": {
        "task_id": {
          "type": "string"
        },
        "goal": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "plan": {
          "items": {
            "$ref": "#/$defs/Step"
          },
          "type": "array"
        },
        "current_step": {
          "type": "integer"
        },
        "metadata": {
          "type": "object"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "task_id",
        "goal",
        "status",
        "current_step",
        "created_at",
        "updated_at"
      ]
    }
  }
}